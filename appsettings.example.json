{
  // Copy this file to appsettings.local.json and edit for your environment.
  // appsettings.local.json is gitignored and will not be committed.
  //
  // Sensitive values (passwords, tokens) should use environment variables instead:
  //   Fennath__Dns__Loopia__Password=your-api-password
  //   Fennath__Telemetry__Headers__Authorization=Basic ...

  "Fennath": {
    "Domain": "example.com",
    "Dns": {
      "Provider": "loopia",
      "Loopia": {
        "Username": "user@loopiaapi",
        "Password": ""
      },
      "PublicIpCheckIntervalSeconds": 300,
      "IpEchoServices": [
        "https://api.ipify.org",
        "https://icanhazip.com",
        "https://checkip.amazonaws.com"
      ]
    },
    "Certificates": {
      "Email": "admin@example.com",
      "Wildcard": true,
      "Staging": true,
      "StoragePath": "/data/certs"
    },
    "Routes": [
      {
        "Subdomain": "@",
        "Backend": "http://localhost:8080",
        "// comment": "@ routes the bare domain (e.g. example.com) — follows DNS apex convention"
      },
      {
        "Subdomain": "grafana",
        "Backend": "http://localhost:3000",
        "HealthCheck": {
          "Path": "/api/health",
          "IntervalSeconds": 30
        }
      },
      {
        "Subdomain": "git",
        "Backend": "http://192.168.1.50:3000"
      }
    ],
    "Docker": {
      "Enabled": false,
      "SocketPath": "/var/run/docker.sock"
    },
    "Server": {
      "HttpsPort": 443,
      "HttpPort": 80,
      "HttpToHttpsRedirect": true
    }
  }
}
