root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,slnx,xml}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile]
indent_size = 4

[*.cs]
# Prefer primary constructors (C# 12+)
csharp_style_prefer_primary_constructors = true:warning
