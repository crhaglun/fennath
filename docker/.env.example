# Fennath Docker Environment
#
# This file is for Docker Compose variable substitution in the YAML itself
# (e.g., DOCKER_GID for socket access). Container-level configuration has
# moved to per-service env files — see docker/env/*.env.example.
#
# Copy to .env and adjust values. The .env file is gitignored.

# Docker socket group ID — find with: stat -c '%g' /var/run/docker.sock
# Common values: 0 (Docker Desktop), 999 or 998 (Linux)
DOCKER_GID=999
