# Fennath Docker Environment — Operator Architecture (ADR-014)
# Copy to .env and fill in your values. The .env file is gitignored.
#
# The proxy container gets: Domain, Server settings (NO Docker socket, NO DNS creds)
# The Operator container gets: Domain, Docker socket, DNS credentials, Certificate settings
# They communicate via a shared Docker volume (/data/shared).

# Docker socket group ID — find with: stat -c '%g' /var/run/docker.sock
# Common values: 0 (Docker Desktop), 999 or 998 (Linux)
DOCKER_GID=0

# ─── Required (both containers) ───────────────────────────────────────────────
Fennath__Domain=example.com

# ─── Required (Operator only — proxy never sees these) ─────────────────────────
# Loopia credentials are Docker secrets — see docker/secrets/README.md
Fennath__Certificates__Email=admin@example.com

# ─── Optional ─────────────────────────────────────────────────────────────────

# Scope all services under a subdomain prefix (e.g., "lab" → services at *.lab.example.com)
#Fennath__Subdomain=

# Non-root container — use unprivileged ports internally (proxy only)
Fennath__Server__HttpsPort=8443
Fennath__Server__HttpPort=8080

# Operator settings
#Fennath__Certificates__Staging=true
#Fennath__Certificates__RenewalCheckIntervalSeconds=86400
#Fennath__Certificates__RenewalThresholdDays=30
#Fennath__Certificates__DnsPropagationTimeoutSeconds=86400
#Fennath__Certificates__DnsPropagationPollingIntervalSeconds=60
#Fennath__Certificates__ChallengePollingIntervalSeconds=120
#Fennath__Dns__PublicIpCheckIntervalSeconds=300
#Fennath__Docker__SocketPath=/var/run/docker.sock
#Fennath__Docker__PollIntervalSeconds=15

# Static routes — for non-Docker backends (VMs, NAS, physical hosts)
# Use JSON config (appsettings.local.json) for readability, or env vars:
#Fennath__StaticRoutes__0__Subdomain=nas
#Fennath__StaticRoutes__0__BackendUrl=http://192.168.1.50:5000
#Fennath__StaticRoutes__1__Subdomain=pve
#Fennath__StaticRoutes__1__BackendUrl=https://192.168.1.10:8006

# ─── Multi-operator deployment (ADR-018) ───────────────────────────────────────
# To serve multiple domains from one proxy, deploy multiple operator containers
# (one per domain). Each operator writes to its own config file and cert subdirectory.
#
# Proxy — list all operator config files (defaults to single /data/shared/yarp-config.json):
#Fennath__YarpConfigPaths__0=/data/shared/yarp-config-lab.json
#Fennath__YarpConfigPaths__1=/data/shared/yarp-config-apps.json
#
# Each operator — unique config path and cert subdirectory:
#Fennath__YarpConfigPath=/data/shared/yarp-config-lab.json
#Fennath__Certificates__StoragePath=/data/shared/certs/lab
#
# Docker containers declare which operator they belong to:
#   fennath.subdomain: grafana
#   fennath.domain: lab.example.com

# Logging
#Logging__LogLevel__Fennath=Debug
#Logging__LogLevel__System.Net.Http.HttpClient=Debug

# OpenTelemetry — uses standard OTEL_* environment variables
#OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-endpoint/otlp
#OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...
#OTEL_EXPORTER_OTLP_PROTOCOL=grpc
