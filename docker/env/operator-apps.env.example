# Operator container environment — apps.example.org
# Copy to operator-apps.env and adjust values.
# Loopia credentials are Docker secrets (not env vars) — see secrets/README.md.

OTEL_SERVICE_NAME=fennath-operator-apps

# Domain identity
Fennath__Domain=example.org

# Where this operator writes its YARP config and certificates
Fennath__YarpConfigPath=/data/shared/yarp-config-apps.json
Fennath__Certificates__StoragePath=/data/shared/certs/apps
Fennath__Certificates__Email=admin@example.org

# Static routes — physical hosts and VMs on this domain
#Fennath__StaticRoutes__0__Subdomain=wiki
#Fennath__StaticRoutes__0__BackendUrl=http://192.168.1.60:3000

# ACME settings
#Fennath__Certificates__Staging=true
