# Shared environment — values common to all containers
# Copy to common.env and adjust values.

# Docker socket group ID — find with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# Certificate storage — shared volume, all operators write here
Fennath__Certificates__StoragePath=/data/shared/certs

# OpenTelemetry (optional)
#OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-endpoint/otlp
#OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...
#OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
