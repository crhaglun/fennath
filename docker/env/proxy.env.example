# Proxy container environment
# Copy to proxy.env and adjust values.

OTEL_SERVICE_NAME=fennath-proxy

# Server ports (internal, mapped to 80/443 in docker-compose)
Fennath__Server__HttpsPort=8443
Fennath__Server__HttpPort=8080

# YARP config files — one per operator
Fennath__YarpConfigPaths__0=/data/shared/yarp-config-lab.json
#Fennath__YarpConfigPaths__1=/data/shared/yarp-config-apps.json
