{
  // Copy this file to appsettings.local.json and edit for your environment.
  // appsettings.local.json is gitignored and will not be committed.
  //
  // The proxy container reads route configuration from the shared volume
  // (yarp-config.json, written by the sidecar). DNS, Docker, and certificate
  // settings belong in the sidecar configuration, not here.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      // Set to "Debug" for detailed application logging:
      // "Fennath": "Debug",
      // Set to "Debug" or "Trace" for outgoing HTTP request/response logging:
      // "System.Net.Http.HttpClient": "Debug"
    }
  },

  "Fennath": {
    "Domain": "example.com",
    // Optional: scope all services under a subdomain prefix.
    // E.g., "lab" → services at *.lab.example.com
    // "Subdomain": "lab",
    "Server": {
      "HttpsPort": 443,
      "HttpPort": 80
    }
  }
}
